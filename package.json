{
  "name": "fu-application",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Files Únicos",
  "main": "src/presentation/electron/main.js",
  "author": "Tu Nombre",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "build:electron": "electron-builder",
    "start": "electron .",
    "test": "jest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7",
    "axios": "^1.6.2",
    "date-fns": "^3.0.0",
    "lucide-react": "^0.300.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.0",
    "better-sqlite3": "^9.2.2",
    "exceljs": "^4.4.0",
    "zod": "^3.22.4",
    "react-hook-form": "^7.49.2",
    "@hookform/resolvers": "^3.3.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.ovi.fu-application",
    "productName": "FU Application",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/presentation/electron/**/*",
      "src/infrastructure/**/*",
      "src/domain/**/*",
      "src/application/**/*",
      "src/shared/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "src/presentation/ui/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/presentation/ui/assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "src/presentation/ui/assets/icon.png"
    }
  }
}
